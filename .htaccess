# Bizual.ai — Apache/LiteSpeed config
# Works both standalone (static) and behind Hostinger Node.js proxy.

DirectoryIndex index.html

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Extensionless URLs: /sales -> sales.html (if the .html exists)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# Disable directory listing
Options -Indexes

# Block source/config files from being served (root is the web root)
<FilesMatch "^(server\.js|package\.json|package-lock\.json|.*\.md)$">
  Require all denied
</FilesMatch>
# Block dependency, VCS and tooling directories
RedirectMatch 404 ^/(node_modules|\.git|\.claude)(/|$)

# Charset for text + llms.txt
AddDefaultCharset UTF-8
<IfModule mod_mime.c>
  AddType text/plain .txt
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header unset X-Powered-By
</IfModule>

# Custom 404 (optional)
ErrorDocument 404 /index.html
