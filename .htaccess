# Bizual.ai — .htaccess de la RAÍZ del repo (red de seguridad)
#
# Lo ideal: configurar el document root del sitio en Hostinger -> /public
# (ahí actúa public/.htaccess). Este archivo es un seguro por si el document
# root quedara apuntando a la raíz del repo: bloquea código/config y enruta
# el sitio hacia /public igualmente.

DirectoryIndex public/index.html
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forzar HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Nunca exponer código fuente, manifiestos ni directorios internos
  RewriteRule ^(server\.js|package(-lock)?\.json)$ - [F]
  RewriteRule \.md$ - [F]
  RewriteRule ^(node_modules|\.git|\.claude)(/|$) - [F]

  # Si el document root es la raíz del repo, servir el sitio desde /public
  RewriteRule ^public/ - [L]
  RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
  RewriteRule ^(.*)$ public/$1 [L]
  RewriteCond %{DOCUMENT_ROOT}/public/$1.html -f
  RewriteRule ^(.+?)/?$ public/$1.html [L]
</IfModule>

# Bloqueo adicional por si mod_rewrite no estuviera disponible
<FilesMatch "^(server\.js|package\.json|package-lock\.json|.*\.md)$">
  Require all denied
</FilesMatch>
